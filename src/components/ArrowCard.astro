---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
  showYear?: boolean;
}

const { entry, showYear = true } = Astro.props;
---

<a href={`/${entry.data.date.getFullYear()}/${entry.slug.replace(/^\d{4}-\d{2}-\d{2}-/, "")}/`} class="relative group flex flex-nowrap py-3 px-4 pr-10 rounded-lg border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out">
  <div class="flex flex-1 min-w-0 gap-4">
    <div class="flex flex-col flex-1 min-w-0">
      <div class="font-semibold">
        {entry.data.title}
      </div>
      <div class="text-sm">
        {entry.data.description}
      </div>
    </div>
    <span class="shrink-0 text-xs text-black/50 dark:text-white/50 mt-0.5">{formatDate(entry.data.date, showYear)}</span>
  </div>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox="0 0 24 24"
    class="absolute top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
    <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
  </svg>
</a>
