---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { 
        year: post.data.date.getFullYear().toString(),
        slug: post.slug.replace(/^\d{4}-\d{2}-\d{2}-/, "")
    },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();

// Resolve the og:image URL from frontmatter.
// Relative paths (e.g. "./images/foo.png") refer to images co-located with the
// blog post in src/content and need to be resolved through Astro's image pipeline
// to get the optimized URL.  Absolute paths (e.g. "/assets/...") refer to files
// in public/ and are passed through as-is.
let image: string | undefined = post.data.image;
if (image && !image.startsWith("/")) {
  const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/content/blog/**/*.{png,jpg,jpeg,gif,webp,svg}",
    { eager: true },
  );
  // Resolve the relative frontmatter path (e.g. "./images/trmnl-ipad.png")
  // against the post's directory to build the full glob key.
  const postDir = `/src/content/blog/${post.id.replace(/\/[^/]+$/, "")}`;
  const resolved = `${postDir}/${image.replace(/^\.\//, "")}`;
  const match = images[resolved];
  if (match) {
    image = match.default.src;
  }
}
---

<PageLayout title={post.data.title} description={post.data.description} image={image}>
  <Container>
    <div class="space-y-1">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body)}
        </div>
      </div>
      <div class="animate text-2xl font-semibold text-black dark:text-white">
        {post.data.title}
      </div>
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>